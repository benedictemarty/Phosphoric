10 REM ULA-NG - COPPER / PALETTE PAR SCANLINE (SECTION 5.4)
20 CLS
30 FOR L=1 TO 24
40 PRINT "ULA-NG COPPER RASTER BARS - PALETTE RE-LATCHED PER SCANLINE";
50 NEXT L
60 POKE#340,78:POKE#340,71
70 REM NG_MODE.B0 = EXTENSIONS ACTIVES
80 POKE#341,1
90 REM RESET DE LA LISTE COPPER
100 POKE#34B,0
110 REM ENTREE = LIGNE, (INDEX*16)OR R, (G*16)OR B ; RECOLORE L'INDEX 7 (BLANC=ENCRE)
120 FOR L=0 TO 199 STEP 6
130 R=L AND 15
140 G=(L/6) AND 15
150 POKE#34C,L
160 POKE#34C,112 OR R
170 POKE#34C,G*16
180 NEXT L
190 GOTO 190
