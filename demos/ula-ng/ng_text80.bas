10 REM ULA-NG - TEXTE 80 COLONNES (SECTION 5.8)
20 FOR A=#A000 TO #A8BF:POKE A,32:NEXT
30 A$="PHOSPHORIC -- ULA-NG -- 80 COLUMN TEXT MODE  (NG_MODE.B2-3 = 10)"
40 FOR C=1 TO LEN(A$):POKE#A000+2*80+5+C,ASC(MID$(A$,C,1)):NEXT
50 B$="THIS SINGLE LINE HOLDS EIGHTY CHARACTERS - IMPOSSIBLE ON THE STOCK 40-COL ULA"
60 FOR C=1 TO LEN(B$):POKE#A000+5*80+2+C,ASC(MID$(B$,C,1)):NEXT
70 D$="0123456789012345678901234567890123456789012345678901234567890123456789012345"
80 FOR C=1 TO LEN(D$):POKE#A000+7*80+2+C,ASC(MID$(D$,C,1)):NEXT
90 E$="THE FONT IS THE ORIC RAM CHARSET AT $B400 - FULLY REDEFINABLE"
100 FOR C=1 TO LEN(E$):POKE#A000+10*80+4+C,ASC(MID$(E$,C,1)):NEXT
110 POKE#340,78:POKE#340,71
120 POKE#341,9
130 GOTO 130
