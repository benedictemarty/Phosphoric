10 REM ULA-NG - SPRITE MATERIEL 16x16 (SECTION 5.7)
20 CLS
30 PRINT "ULA-NG HARDWARE SPRITE (16x16) - BOUNCING DIAMOND"
40 POKE#340,78:POKE#340,71
50 REM NG_SPR_CTRL.B0 = ENABLE GLOBAL
60 POKE#350,1
70 REM SELECTIONNE LE SPRITE 0 (REMET LE POINTEUR MOTIF A 0)
80 POKE#351,0
90 REM MOTIF 16x16 : LOSANGE JAUNE (INDEX 3) SUR FOND TRANSPARENT (0)
100 FOR R=0 TO 15:FOR C=0 TO 15
110 IF ABS(R-7)+ABS(C-7)<8 THEN POKE#355,3 ELSE POKE#355,0
120 NEXT C:NEXT R
130 REM SPRITE 0 VISIBLE
140 POKE#354,1
150 X=0:DX=2:Y=60
160 POKE#352,X:POKE#353,Y
170 X=X+DX:IF X>200 OR X<2 THEN DX=-DX
180 FOR W=1 TO 20:NEXT
190 GOTO 160
