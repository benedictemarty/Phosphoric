10 REM PICOWIFI MODEM TEST (LOCI ACIA 0380)
20 REM RUN WITH:
30 REM   --acia-addr 0380 --serial picowifi:HomeNet --serial-buffer 512
40 CLS
50 DA=896:ST=897:CM=898:CT=899
60 REM --- INIT ACIA 9600 8N1, DTR ON ---
70 POKE ST,0:POKE CT,30:POKE CM,3
80 PRINT"*** TEST MODEM PICOWIFI ***"
90 PRINT
100 A$="ATI"+CHR$(13):GOSUB 1000
110 A$="AT$SSID=PHOSPHORIC"+CHR$(13):GOSUB 1000
120 A$="ATC1"+CHR$(13):GOSUB 1000
130 A$="AT$SSID?"+CHR$(13):GOSUB 1000
140 A$="ATC?"+CHR$(13):GOSUB 1000
150 PRINT:PRINT"*** FIN ***":END
1000 REM --- ENVOIE A$ ET AFFICHE LA REPONSE ---
1010 FOR I=1 TO LEN(A$)
1020 IF (PEEK(ST) AND 16)=0 THEN 1020
1030 POKE DA,ASC(MID$(A$,I,1)):NEXT I
1040 T=0
1050 S=PEEK(ST):IF (S AND 8)=0 THEN T=T+1:IF T<3000 THEN 1050
1060 IF (S AND 8)=0 THEN PRINT:RETURN
1070 C=PEEK(DA):T=0
1080 IF C=13 THEN PRINT:GOTO 1050
1090 IF C=10 THEN 1050
1100 PRINT CHR$(C);:GOTO 1050
