10 REM DIGITELEC DTL 2000 TEST
20 REM PIA 6821 + ACIA 6850 AT #3F8-#3FD
30 REM RUN WITH: --dtl2000 loopback
40 CLS
50 PRINT"*** DIGITELEC DTL 2000 ***"
60 PRINT"PIA 6821 + ACIA 6850 #3F8"
70 PRINT
80 REM REGISTER ADDRESSES (DECIMAL)
90 REM NB: BASIC ORIC = 2 CARS SIGNIFICATIFS (CRA/CRB COLLISIONNENT EN CR)
95 PA=1016:AA=1017:CS=1020:DA=1021
100 REM --- INIT ASYMETRIQUE V23 (DEPUIS NOTICE) ---
110 POKE AA,0   :REM CRA: SELECTION DDRA
120 POKE PA,244  :REM DDRA = #F4
130 POKE CS,3    :REM ACIA MASTER RESET
140 POKE AA,4   :REM CRA: SELECTION OR
150 POKE PA,212  :REM OR = #D4 (LIGNE OUVERTE)
160 POKE CS,73   :REM ACIA = #49 (7E1)
170 S=PEEK(CS)
180 T=(S AND 2)/2
190 PRINT"TEST 1 TDRE=";T
200 D=(S AND 4)/4
210 PRINT"TEST 2 DCD (1=PAS PORTEUSE)=";D
220 REM --- CONNEXION LIGNE ---
230 POKE PA,208  :REM OR = #D0 (LIGNE FERMEE)
240 POKE CS,9    :REM ORDRE EMISSION PORTEUSE
250 S=PEEK(CS)
260 D=(S AND 4)/4
270 PRINT"TEST 3 DCD APRES CONNEXION=";D
280 REM --- ALLER-RETOUR LOOPBACK ---
290 OK=0
300 FOR I=0 TO 9
310 C=65+I
320 IF (PEEK(CS) AND 2)=0 THEN GOTO 320
330 POKE DA,C   :REM EMET LE CARACTERE
340 FOR W=1 TO 200:NEXT W
350 IF (PEEK(CS) AND 1)=0 THEN GOTO 380
360 V=PEEK(DA)  :REM LIT LE CARACTERE RECU
370 IF V=C THEN OK=OK+1
380 NEXT I
390 PRINT"TEST 4 LOOPBACK=";OK;"/10"
400 PRINT
410 PRINT"TESTS TERMINES"
420 PRINT"T = MODE TERMINAL"
430 GET A$
440 IF A$<>"T" THEN END
450 CLS
460 PRINT"TERMINAL DTL 2000 (ESC=FIN)"
470 PRINT
480 REM RX: BIT0 DE CS
490 IF (PEEK(CS) AND 1)=0 THEN GOTO 540
500 C=PEEK(DA)
510 IF C=13 THEN PRINT
520 IF C>31 AND C<127 THEN PRINT CHR$(C);
530 REM TX: ATTENDRE TDRE (BIT1) PUIS EMETTRE
540 K$=KEY$
550 IF K$="" THEN GOTO 490
560 IF ASC(K$)=27 THEN END
570 IF (PEEK(CS) AND 2)=0 THEN GOTO 570
580 POKE DA,ASC(K$)
590 GOTO 490
