10 REM DTL 2000 ECHO — RX (replay) -> TX (capture)
20 REM RUN WITH: --dtl2000 file:IN:OUT  (5 octets attendus)
30 REM NB: ORIC BASIC = 2 CARS SIGNIFICATIFS -> PA/AA/CS/DA
40 PA=1016:AA=1017:CS=1020:DA=1021
50 REM --- CONNEXION LIGNE + ACIA (8N1 EMISSION PORTEUSE) ---
60 POKE AA,0   :REM CRA: SELECTION DDRA
70 POKE PA,244  :REM DDRA = #F4
80 POKE AA,4   :REM CRA: SELECTION OR
90 POKE PA,192  :REM OR = #C0 (LIGNE FERMEE, MODE SYMETRIQUE)
100 POKE CS,3    :REM ACIA MASTER RESET
110 POKE CS,21   :REM ACIA = #15 (8N1, DIV16, RTS BAS = EMISSION)
120 REM --- BOUCLE ECHO : LIT RX, RENVOIE EN TX ---
130 FOR I=1 TO 5
140 IF (PEEK(CS) AND 1)=0 THEN GOTO 140
150 C=PEEK(DA)  :REM OCTET RECU (REJOUE DEPUIS LE FICHIER)
160 IF (PEEK(CS) AND 2)=0 THEN GOTO 160
170 POKE DA,C   :REM RENVOIE EN TX (CAPTURE DANS LE FICHIER)
180 NEXT I
190 PRINT"ECHO 5 OCTETS OK"
200 END
