10 REM *** CLAUDE SUR ORIC-1 *** API ANTHROPIC VIA PICOWIFI (LOCI ACIA 0380)
20 REM RUN: --loci --acia-addr 0380 --serial com:9600,8,N,1,/dev/ttyACM0 --serial-buffer 4096
30 DA=896:ST=897:CM=898:CT=899
40 KY$="sk-ant-REMPLACEZ-PAR-VOTRE-CLE"
50 MD$="claude-haiku-4-5-20251001"
60 POKE ST,0:POKE CT,30:POKE CM,3
70 CLS:PRINT"=== CLAUDE SUR ORIC-1 ==="
80 PRINT"API ANTHROPIC / MODEM PICOWIFI"
90 PRINT
100 PRINT"INIT MODEM...":A$="ATE0"+CHR$(13):GOSUB 900:GOSUB 2000
120 A$="ATI"+CHR$(13):GOSUB 900:GOSUB 950
125 PRINT"(SI HORS LIGNE: ATC1 / AT$SSID=...)"
130 PRINT:PRINT"VOUS> ";:GOSUB 3000
140 IF Q$="" THEN 130
150 IF Q$="BYE" THEN PRINT"AU REVOIR.":END
200 REM --- ENVOI ATPOST ---
210 A$="ATPOSThttps://api.anthropic.com/v1/messages"+CHR$(13):GOSUB 900
220 GOSUB 2000
240 A$="x-api-key: "+KY$+CHR$(10):GOSUB 900
250 A$="anthropic-version: 2023-06-01"+CHR$(10):GOSUB 900
260 A$="content-type: application/json"+CHR$(10):GOSUB 900
270 A$=CHR$(10):GOSUB 900
290 A$="{"+CHR$(34)+"model"+CHR$(34)+":"+CHR$(34)+MD$+CHR$(34)+",":GOSUB 900
300 A$=CHR$(34)+"max_tokens"+CHR$(34)+":300,":GOSUB 900
310 A$=CHR$(34)+"system"+CHR$(34)+":"+CHR$(34)+"REPLY IN PLAIN ASCII UPPERCASE NO ACCENTS MAX 6 SHORT LINES ORIC SCREEN"+CHR$(34)+",":GOSUB 900
320 A$=CHR$(34)+"messages"+CHR$(34)+":[{"+CHR$(34)+"role"+CHR$(34)+":"+CHR$(34)+"user"+CHR$(34)+","+CHR$(34)+"content"+CHR$(34)+":"+CHR$(34):GOSUB 900
340 FOR I=1 TO LEN(Q$):C=ASC(MID$(Q$,I,1))
350 IF C=34 THEN A$=CHR$(92)+CHR$(34):GOSUB 900:GOTO 390
360 IF C=92 THEN A$=CHR$(92)+CHR$(92):GOSUB 900:GOTO 390
370 IF C<32 THEN C=32
380 A$=CHR$(C):GOSUB 900
390 NEXT I
400 A$=CHR$(34)+"}]}"+CHR$(10):GOSUB 900
410 A$="."+CHR$(10):GOSUB 900
500 REM --- LECTURE: DE-CHUNK HTTP + EXTRAIT "text":" ---
510 T$=CHR$(34)+"text"+CHR$(34)+":"+CHR$(34):TL=LEN(T$)
512 MP=1:FD=0:ES=0:PH=0:LN=0:SZ=0:CN=0:DN=0:HS=0
520 TT=0:PRINT:PRINT"CLAUDE> ";
530 S=PEEK(ST)
540 IF (S AND 8)=0 THEN TT=TT+1:IF TT>8000 THEN 700
545 IF (S AND 8)=0 THEN 530
550 C=PEEK(DA):TT=0
552 IF PH=2 THEN GOSUB 1600:GOTO 560
553 IF PH=0 THEN GOSUB 1500:GOTO 560
554 IF PH=1 THEN GOSUB 1550:GOTO 560
555 IF PH=3 THEN IF C=10 THEN PH=1:SZ=0
560 IF DN=1 THEN 700
562 GOTO 530
700 PRINT:A$="ATH"+CHR$(13):GOSUB 900:GOSUB 2000:GOTO 130
800 REM --- TRADUIT ECHAPPEMENT JSON ---
810 IF C=110 THEN PRINT:RETURN
820 IF C=116 THEN PRINT" ";:RETURN
830 IF C=34 THEN PRINT CHR$(34);:RETURN
840 IF C=92 THEN PRINT CHR$(92);:RETURN
850 IF C=47 THEN PRINT"/";:RETURN
860 IF C=117 THEN RETURN
870 PRINT CHR$(C);:RETURN
900 REM --- ENVOIE A$ TEL QUEL ---
910 FOR J=1 TO LEN(A$)
920 IF (PEEK(ST) AND 16)=0 THEN 920
930 POKE DA,ASC(MID$(A$,J,1)):NEXT J:RETURN
950 REM --- LIT + AFFICHE REPONSE AT (BORNEE) ---
952 TT=0
954 IF (PEEK(ST) AND 8)<>0 THEN 970
956 TT=TT+1:IF TT<2500 THEN 954
958 PRINT:RETURN
970 S=PEEK(ST):IF (S AND 8)=0 THEN TT=TT+1:IF TT<300 THEN 970
980 IF (S AND 8)=0 THEN PRINT:RETURN
990 C=PEEK(DA):TT=0:IF C=13 THEN PRINT:GOTO 970
995 IF C=10 THEN 970
998 PRINT CHR$(C);:GOTO 970
1500 REM --- PH0: SAUTE LES EN-TETES HTTP (FIN = LIGNE VIDE APRES DEBUT) ---
1510 IF C=13 THEN RETURN
1520 IF C<>10 THEN LN=LN+1:RETURN
1530 IF LN=0 AND HS=1 THEN PH=1:SZ=0:RETURN
1540 IF LN>0 THEN HS=1
1545 LN=0:RETURN
1550 REM --- PH1: TAILLE DE CHUNK (HEX) JUSQU'AU LF ---
1555 IF C=13 THEN RETURN
1560 IF C=10 THEN IF SZ=0 THEN DN=1:RETURN
1562 IF C=10 THEN PH=2:CN=SZ:RETURN
1565 IF C>=48 AND C<=57 THEN SZ=SZ*16+(C-48):RETURN
1570 IF C>=65 AND C<=70 THEN SZ=SZ*16+(C-55):RETURN
1575 IF C>=97 AND C<=102 THEN SZ=SZ*16+(C-87):RETURN
1580 RETURN
1600 REM --- PH2: DONNEES DU CHUNK -> SCANNER ---
1610 GOSUB 1700:CN=CN-1:IF CN<=0 THEN PH=3
1620 RETURN
1700 REM --- SCANNER: CHERCHE "text":" PUIS AFFICHE ---
1710 IF FD=1 THEN 1740
1720 IF C=ASC(MID$(T$,MP,1)) THEN MP=MP+1:GOTO 1730
1725 MP=1:IF C=ASC(MID$(T$,1,1)) THEN MP=2
1730 IF MP>TL THEN FD=1
1735 RETURN
1740 IF ES=1 THEN GOSUB 800:ES=0:RETURN
1745 IF C=92 THEN ES=1:RETURN
1750 IF C=34 THEN DN=1:RETURN
1755 PRINT CHR$(C);:RETURN
2000 REM --- VIDE LE TAMPON RX ---
2010 TT=0
2020 IF (PEEK(ST) AND 8)=0 THEN TT=TT+1:IF TT<300 THEN 2020
2030 IF (PEEK(ST) AND 8)=0 THEN RETURN
2040 C=PEEK(DA):TT=0:GOTO 2020
3000 REM --- SAISIE CLAVIER (VIRGULES OK, CORRECTION) ---
3010 Q$=""
3020 GET K$:K=ASC(K$)
3030 IF K=13 THEN PRINT:RETURN
3040 IF K<>127 AND K<>8 THEN 3060
3050 IF LEN(Q$)>0 THEN Q$=LEFT$(Q$,LEN(Q$)-1):PRINT CHR$(8);" ";CHR$(8);
3055 GOTO 3020
3060 IF K<32 THEN 3020
3070 IF LEN(Q$)>=200 THEN 3020
3080 Q$=Q$+K$:PRINT K$;:GOTO 3020
