10 REM ===== TERMINAL WIFI LOCI ($0380) - Phosphoric =====
20 B=#380
30 POKE B+1,0
40 POKE B+3,#1E
50 POKE B+2,#0B
60 PRINT "TERMINAL WIFI LOCI - CTRL-C POUR QUITTER"
70 PRINT "TAPEZ DES COMMANDES AT (EX: ATI puis RETURN)"
80 PRINT
90 REM --- boucle full duplex ---
100 S = PEEK(B+1)
110 IF (S AND #08) = 0 THEN 160
120 C = PEEK(B)
130 IF C = 13 THEN PRINT
140 IF C > 31 AND C < 127 THEN PRINT CHR$(C);
150 GOTO 100
160 K$ = KEY$
170 IF K$ = "" THEN 100
180 IF (PEEK(B+1) AND #10) = 0 THEN 180
190 POKE B,ASC(K$)
200 GOTO 100
