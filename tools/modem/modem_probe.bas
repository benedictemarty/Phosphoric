10 B=#380
20 POKE B+1,0
30 POKE B+3,#1E
40 POKE B+2,#0B
50 A$ = "ATI" + CHR$(13)
60 FOR I = 1 TO LEN(A$)
70 IF (PEEK(B+1) AND #10) = 0 THEN 70
80 POKE B,ASC(MID$(A$,I,1))
90 NEXT I
100 IF (PEEK(B+1) AND #08) = 0 THEN 100
110 C = PEEK(B)
120 IF C = 13 THEN PRINT
130 IF C > 31 AND C < 127 THEN PRINT CHR$(C);
140 GOTO 100
