10 REM ===== TERMINAL NNTP (CRLF) LOCI $0380 =====
20 B=#380
30 POKE B+1,0
40 POKE B+3,#1E
50 POKE B+2,#0B
60 PRINT "TERMINAL NNTP CRLF - CTRL-C QUITTE"
70 PRINT
100 S = PEEK(B+1)
110 IF (S AND #08) = 0 THEN 160
120 C = PEEK(B)
130 IF C = 13 THEN PRINT
140 IF C > 31 AND C < 127 THEN PRINT CHR$(C);
150 GOTO 100
160 K$ = KEY$
170 IF K$ = "" THEN 100
175 D = ASC(K$)
180 IF (PEEK(B+1) AND #10) = 0 THEN 180
190 POKE B,D
195 IF D <> 13 THEN 100
200 IF (PEEK(B+1) AND #10) = 0 THEN 200
210 POKE B,10
220 GOTO 100
